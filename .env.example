# ── Groq API Keys ──────────────────────────────────────────
# GROQ_API_KEY_LIGHT is used for: intent classifier fallback,
#   CRAG grader, hallucination checker, response expander
# GROQ_API_KEY_MAIN is used for: generator (70b), RAGAS evaluator
GROQ_API_KEY_LIGHT=gsk_your_light_key_here
GROQ_API_KEY_MAIN=gsk_your_main_key_here

# ── Cohere (embeddings) ───────────────────────────────────
COHERE_API_KEY=your_cohere_trial_key_here

# ── MongoDB Atlas ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true

# ── Optional: OpenAI (if using OpenAI as RAGAS evaluator) ─
# OPENAI_API_KEY=sk-your_key_here
